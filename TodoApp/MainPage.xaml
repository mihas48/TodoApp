<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TodoApp.MainPage">

    <ScrollView>
        <VerticalStackLayout Margin="200, 50">
            <!-- Поле и кнопка для ввода новой задачи -->
            <Grid ColumnDefinitions="*, auto" RowDefinitions="auto">
                <Entry x:Name="entryForNewListItem" Grid.Column="0" MinimumWidthRequest="500" MinimumHeightRequest="40" 
                       Placeholder="Введите название новой задачи" HorizontalOptions="Start"/>
                <Button HorizontalOptions="End" MinimumWidthRequest="75" Command="{Binding AddNewListItemCommand}"
                        CommandParameter="{Binding Text, Source={x:Reference entryForNewListItem}}"/>
            </Grid>
            <!-- Пространоство для активных задач -->
            <VerticalStackLayout Margin="0, 20">
                <Border Stroke="Gray" HeightRequest="400">
                </Border>
            </VerticalStackLayout>
            <!-- Пространство для выполненных задач -->
            <VerticalStackLayout Margin="0, 5">
                <Border Stroke="Gray" HeightRequest="400">
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
